---
import { cities } from '../data/cities';

const sortedCities = [...cities].sort((a, b) => a.name.localeCompare(b.name));
---

<section class="py-10 px-6 md:px-8 border-t border-border/60" id="service-areas">
  <div class="max-w-[1100px] mx-auto text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gray mb-4">
      Serving the DFW Metroplex
    </p>
    <p class="text-sm text-gray-text leading-relaxed">
      {sortedCities.map((city, i) => (
        <>
          <a
            href={`/${city.slug}/`}
            class="hover:text-black transition-colors duration-200"
          >{city.name}</a>{i < sortedCities.length - 1 && <span class="mx-1.5 text-border">&middot;</span>}
        </>
      ))}
    </p>
  </div>
</section>
