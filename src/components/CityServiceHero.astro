---
import Breadcrumb from './Breadcrumb.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  headline: string;
  intro: string;
  breadcrumbs: BreadcrumbItem[];
  backgroundImage?: string;
  sectionLabel?: string;
}

const { headline, intro, breadcrumbs, backgroundImage, sectionLabel } = Astro.props;
---

<section
  class="relative overflow-hidden text-white pt-36 pb-24 px-6 md:px-8"
  style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}
>
  {/* Dark overlay + gradient */}
  <div class="absolute inset-0 bg-dark/80"></div>
  {backgroundImage && (
    <div class="absolute inset-0">
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/75 to-dark/60"></div>
    </div>
  )}

  {/* Grain texture */}
  <div class="grain absolute inset-0"></div>

  <div class="relative z-10 max-w-[1318px] mx-auto">
    <div class="mb-6">
      <Breadcrumb items={breadcrumbs.map((b) => ({
        ...b,
        href: b.href,
      }))} />
    </div>

    {sectionLabel && (
      <div class="section-label section-label-light mb-4">
        {sectionLabel}
      </div>
    )}

    <h1 class="font-display text-4xl sm:text-[52px] font-semibold leading-[1.12] tracking-tight mb-6">
      {headline}
    </h1>

    <p class="text-lg text-white/80 max-w-3xl leading-relaxed mb-4">
      {intro}
    </p>

    {/* Trust bar */}
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-white/50 mb-8">
      <span>Est. 2005</span>
      <span class="hidden sm:inline" aria-hidden="true">&middot;</span>
      <span>4.9-Star Rated</span>
      <span class="hidden sm:inline" aria-hidden="true">&middot;</span>
      <span>BBB Accredited</span>
    </div>

    <div>
      <a href="#contact" class="btn btn-primary">
        <span>Get a Free Quote</span>
      </a>
    </div>
  </div>
</section>
